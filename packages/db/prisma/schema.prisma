// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ASTROLOGER
  ADMIN
}

enum SessionStatus {
  ACTIVE
  ENDED
}

enum TransactionType {
  CREDIT
  DEBIT
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String
  role          Role         @default(USER)
  walletBalance   Float    @default(0)
  freeMinutesLeft Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt     DateTime     @updatedAt

  astrologerProfile Astrologer?
  kundliProfile     KundliProfile?
  chatSessions      ChatSession[] @relation("UserSessions")
  sentMessages      Message[]     @relation("SentMessages")
  transactions      Transaction[]
  reviews           Review[]      @relation("UserReviews")
}

model Astrologer {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  speciality      String?
  categories      String[] @default([])
  experienceYears Int      @default(0)
  languages       String   @default("Hindi, English")
  profileImage    String?
  ratePerMin      Float    @default(10)
  isOnline        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chatSessions       ChatSession[]       @relation("AstrologerSessions")
  reviews            Review[]            @relation("AstrologerReviews")
  withdrawalRequests WithdrawalRequest[]
}

model ChatSession {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation("UserSessions", fields: [userId], references: [id])
  astrologerId  String
  astrologer    Astrologer    @relation("AstrologerSessions", fields: [astrologerId], references: [id])
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  totalCost     Float         @default(0) // Gross amount charged to User
  astrologerEarnings Float    @default(0) // Net amount credited to Astrologer
  status        SessionStatus @default(ACTIVE)

  messages Message[]
  review   Review?
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation("SentMessages", fields: [senderId], references: [id])
  content   String
  createdAt DateTime    @default(now())
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Float
  type        TransactionType
  reason      String?
  referenceId String?         @unique
  createdAt   DateTime        @default(now())
}

model Review {
  id           String      @id @default(cuid())
  rating       Int         // 1 to 5
  comment      String?
  userId       String?
  user         User?       @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)
  astrologerId String
  astrologer   Astrologer  @relation("AstrologerReviews", fields: [astrologerId], references: [id], onDelete: Cascade)
  sessionId    String?     @unique
  session      ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reviewerName String?
  createdAt    DateTime    @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

model WithdrawalRequest {
  id           String           @id @default(cuid())
  astrologerId String
  astrologer   Astrologer       @relation(fields: [astrologerId], references: [id], onDelete: Cascade)
  amount       Float
  status       WithdrawalStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  processedAt  DateTime?
}

model KundliProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  dateOfBirth  String   // "YYYY-MM-DD"
  timeOfBirth  String   // "HH:MM"
  placeOfBirth String
  latitude     Float?
  longitude    Float?
  timezone     Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

