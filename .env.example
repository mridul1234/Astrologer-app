# ─── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="https://your-vercel-app.vercel.app"

# ─── Socket Server ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL="https://your-socket-server.onrender.com"
SOCKET_SECRET="your-socket-jwt-secret"

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_..."

# ─── Gupshup WhatsApp (astrologer chat request notifications) ─────────────────
# Sign up at https://www.gupshup.io and create a WhatsApp Business app
GUPSHUP_API_KEY="your-gupshup-api-key"
GUPSHUP_SOURCE_NUMBER="917xxxxxxxxx"   # Your Gupshup sender number (with country code)
GUPSHUP_APP_NAME="your-gupshup-app-name"
